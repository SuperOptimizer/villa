      <item row="3" column="0" colspan="2">
       <widget class="QGroupBox" name="groupBox_5">
        <property name="title">
         <string>Cache</string>
        </property>
        <layout class="QGridLayout" name="gridLayout_5" columnstretch="1,1,0">
         <item row="0" column="0">
          <widget class="QLabel" name="labelRamCacheSize">
           <property name="text">
            <string>RAM cache size (GB)</string>
           </property>
          </widget>
         </item>
         <item row="0" column="1">
          <widget class="QSpinBox" name="spinRamCacheSizeGB">
           <property name="minimum">
            <number>1</number>
           </property>
           <property name="maximum">
            <number>512</number>
           </property>
           <property name="value">
            <number>10</number>
           </property>
           <property name="suffix">
            <string> GB</string>
           </property>
          </widget>
         </item>
         <item row="0" column="2">
          <widget class="QPushButton" name="btnHelpRamCacheSize">
           <property name="sizePolicy">
            <sizepolicy hsizetype="Minimum" vsizetype="Minimum">
             <horstretch>0</horstretch>
             <verstretch>0</verstretch>
            </sizepolicy>
           </property>
           <property name="toolTip">
            <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;Total RAM budget for the in-memory chunk cache (hot + warm tiers).&lt;/p&gt;&lt;p&gt;80% is used for decompressed chunks (hot), 20% for compressed chunks (warm).&lt;/p&gt;&lt;p&gt;Requires restart.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
           </property>
           <property name="text">
            <string/>
           </property>
           <property name="icon">
            <iconset theme="help-contents"/>
           </property>
           <property name="flat">
            <bool>true</bool>
           </property>
          </widget>
         </item>
         <item row="1" column="0">
          <widget class="QLabel" name="labelDiskCacheSize">
           <property name="text">
            <string>Disk cache size (GB)</string>
           </property>
          </widget>
         </item>
         <item row="1" column="1">
          <widget class="QSpinBox" name="spinDiskCacheSizeGB">
           <property name="minimum">
            <number>1</number>
           </property>
           <property name="maximum">
            <number>4096</number>
           </property>
           <property name="value">
            <number>100</number>
           </property>
           <property name="suffix">
            <string> GB</string>
           </property>
          </widget>
         </item>
         <item row="1" column="2">
          <widget class="QPushButton" name="btnHelpDiskCacheSize">
           <property name="sizePolicy">
            <sizepolicy hsizetype="Minimum" vsizetype="Minimum">
             <horstretch>0</horstretch>
             <verstretch>0</verstretch>
            </sizepolicy>
           </property>
           <property name="toolTip">
            <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;Maximum size of the on-disk chunk cache for remote volumes.&lt;/p&gt;&lt;p&gt;Chunks are evicted in LRU order when this limit is exceeded.&lt;/p&gt;&lt;p&gt;Requires restart.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
           </property>
           <property name="text">
            <string/>
           </property>
           <property name="icon">
            <iconset theme="help-contents"/>
           </property>
           <property name="flat">
            <bool>true</bool>
           </property>
          </widget>
         </item>
         <item row="2" column="0">
          <widget class="QLabel" name="labelRemoteCachePath">
           <property name="text">
            <string>Remote cache directory</string>
           </property>
          </widget>
         </item>
         <item row="2" column="1">
          <widget class="QLineEdit" name="edtRemoteCachePath">
           <property name="placeholderText">
            <string>~/.VC3D/remote_cache</string>
           </property>
          </widget>
         </item>
         <item row="2" column="2">
          <widget class="QPushButton" name="btnBrowseRemoteCachePath">
           <property name="text">
            <string>Browse...</string>
           </property>
          </widget>
         </item>
         <item row="3" column="0" colspan="3">
          <widget class="QCheckBox" name="chkVideoRecompress">
           <property name="text">
            <string>Recompress remote chunks with video codec (reduces disk cache size)</string>
           </property>
           <property name="toolTip">
            <string>When enabled, chunks fetched from remote volumes are re-encoded with a video codec before storing to the disk cache. This significantly reduces disk usage at the cost of some quality loss. Requires restart.</string>
           </property>
          </widget>
         </item>
         <item row="4" column="0">
          <widget class="QLabel" name="labelVideoCodecType">
           <property name="text">
            <string>Video codec</string>
           </property>
          </widget>
         </item>
         <item row="4" column="1">
          <widget class="QComboBox" name="cmbVideoCodecType">
           <item>
            <property name="text">
             <string>H.264</string>
            </property>
           </item>
           <item>
            <property name="text">
             <string>H.265</string>
            </property>
           </item>
           <item>
            <property name="text">
             <string>C3D (3D DCT)</string>
            </property>
           </item>
          </widget>
         </item>
         <item row="5" column="0">
          <widget class="QLabel" name="labelVideoQualityPreset">
           <property name="text">
            <string>Compression level</string>
           </property>
          </widget>
         </item>
         <item row="5" column="1">
          <widget class="QComboBox" name="cmbVideoQualityPreset">
           <property name="toolTip">
            <string>Controls quality vs compression ratio. Higher compression = more disk savings but lower fidelity.</string>
           </property>
           <item>
            <property name="text">
             <string>Lossless (1x–5x)</string>
            </property>
           </item>
           <item>
            <property name="text">
             <string>Near-lossless (4x–7x)</string>
            </property>
           </item>
           <item>
            <property name="text">
             <string>High quality (5x–10x)</string>
            </property>
           </item>
           <item>
            <property name="text">
             <string>Balanced (8x–15x)</string>
            </property>
           </item>
           <item>
            <property name="text">
             <string>Compact (15x–30x)</string>
            </property>
           </item>
           <item>
            <property name="text">
             <string>Maximum compression (30x–70x)</string>
            </property>
           </item>
          </widget>
         </item>
         <item row="6" column="0" colspan="3">
          <widget class="QCheckBox" name="chkRechunk32">
           <property name="text">
            <string>Force rechunk to 32³ blocks (optimal for C3D codec)</string>
           </property>
           <property name="toolTip">
            <string>When enabled, chunks are split into 32×32×32 sub-blocks before compression. This is optimal for the C3D codec which natively operates on 32³ blocks, but may also benefit other codecs. Requires restart.</string>
           </property>
          </widget>
         </item>
         <item row="7" column="0">
          <widget class="QLabel" name="lblPrefetchLevels">
           <property name="text">
            <string>Prefetch levels on open:</string>
           </property>
           <property name="toolTip">
            <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;How many of the coarsest pyramid levels to download when opening a remote volume.&lt;/p&gt;&lt;p&gt;E.g., with a volume that has levels 0/ through 5/:&lt;/p&gt;&lt;ul&gt;&lt;li&gt;0 = no prefetch (on-demand only)&lt;/li&gt;&lt;li&gt;1 = download 5/ (already happens by default)&lt;/li&gt;&lt;li&gt;2 = download 5/ and 4/&lt;/li&gt;&lt;li&gt;3 = download 5/, 4/, and 3/&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;Downloads go through the normal pipeline (recompression if enabled). Non-blocking.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
           </property>
          </widget>
