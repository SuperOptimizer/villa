            </sizepolicy>
           </property>
           <property name="toolTip">
            <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;Uses nearest neighbor interpolation instead of linear interpolation.&lt;/p&gt;&lt;p&gt;This improves rendering performance but reduces image quality.&lt;/p&gt;&lt;p&gt;Useful for slower systems or when working with very large volumes.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
