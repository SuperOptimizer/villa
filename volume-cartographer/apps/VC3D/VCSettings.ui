         <item row="4" column="2">
           <widget class="QPushButton" name="btnHelpDownscaleOverride">
             <property name="enabled">
               <bool>true</bool>
             </property>
             <property name="sizePolicy">
               <sizepolicy hsizetype="Minimum" vsizetype="Minimum">
                 <horstretch>0</horstretch>
