{
	"args": {
		"model-init": "seed",
		"init-mode": "shell-dir-crop",
		"self-map-init": "multi_wrap_d",
		"mesh-step": 50.0,
		"init-grow": {
			"enabled": true,
			"initial_depth": 1,
			"order": ["up"],
			"step": 1
		}
	},
	"base": {
		"step": 10.0,
		"smooth": 10.0,
		"station_n": 1.0,
		"station_t": 1.0,
		"corr": 0.0001,
		"pred_dt": 0.0,
		"bend": 100.0,
		"snap_surf_map": 0.01,
		"map_dist": 0.0001,
		"map_vec_normal": 1.0,
		"map_surface_normal": 1.0,
		"map_smooth": 0.1,
		"map_bend": 0.01,
		"map_turn": 0.1,
		"map_jac": 1.0,
		"map_metric_smooth": 0.1,
		"map_area_smooth": 0.0,
		"map_dense_prior": 0.001,
		"map_station_t": 0.001
	},
	"stages": [
		{
			"name": "init_center",
			"steps": 500,
			"lr": 10.0,
			"params": ["mesh_ms"],
			"w_fac": {
				"snap_surf_map": 0.0
			},
			"args": {
				"status_interval": 50
			}
		},
		{
			"name": "expand-z",
			"stages": [
				{
					"name": "expand_up",
					"steps": "auto",
					"lr": 0.1,
					"params": ["mesh_ms"],
					"w_fac": {
						"station_n": 0.0,
						"station_t": 0.0001
					},
					"args": {
						"status_interval": 50,
						"snap_surf_map": {
							"map_opt": {
								"name": "expand_boundary_map",
								"steps": 1,
								"lr": 0.01,
								"params": ["map_surf_ms"],
								"args": {
									"subdiv": 1
								}
							}
						}
					}
				}
			]
		},
		{
			"name": "global",
			"steps": "auto",
			"lr": 0.1,
			"params": ["mesh_ms"],
			"min_scaledown": 0,
			"w_fac": {
				"snap_surf_map": 1.0,
				"station_t": 0.001
			},
			"args": {
				"status_interval": 50,
				"snap_surf_map": {
					"map_opt": {
						"name": "snap_map_opt_reopt",
						"steps": 1,
						"lr": 0.01,
						"params": ["map_surf_ms"],
						"min_scaledown": 0,
						"args": {
							"subdiv": 1
						}
					}
				}
			}
		}
	]
}
