{
	"args": {
		"model-init": "seed",
		"init-mode": "shell-dir-crop",
		"self-map-init": "multi_wrap_full",
		"mesh-step": 50.0
	},
	"base": {
		"normal": 1.0,
		"step": 10.0,
		"smooth": 10.0,
		"station_n": 0.1,
		"station_t": 0.1,
		"winding_density": 0.01,
		"data": 0.0,
		"data_plain": 0.0,
		"pred_dt": 0.001,
		"corr": 0.0,
		"bend": 100.0,
		"ext_offset": 0.0,
		"snap_surf_map": 0.01,
		"map_dist": 0.0001,
		"map_vec_normal": 1.0,
		"map_surface_normal": 1.0,
		"map_smooth": 0.1,
		"map_bend": 0.01,
		"map_turn": 0.1,
		"map_jac": 1.0,
		"map_metric_smooth": 0.1,
		"map_area_smooth": 0.0,
		"map_dense_prior": 0.001,
		"map_station_t": 0.001
	},
	"stages": [
		{
			"name": "stage1",
			"steps": 200,
			"lr": 10.0,
			"params": ["mesh_ms"],
			"min_scaledown": 0,
			"w_fac": {
				"pred_dt": 0.0,
				"station_n": 10.0,
				"station_t": 10.0,
				"snap_surf_map": 0.0
			},
			"args": {
				"status_interval": 50,
				"snap_surf_map": {
					"map_opt": {
						"name": "snap_map_opt_final",
						"steps": 1,
						"lr": 0.01,
						"params": ["map_surf_ms"],
						"min_scaledown": 0,
						"args": {
							"subdiv": 1
						}
					}
				}
			}
		},
		{
			"name": "stage2",
			"steps": 200,
			"lr": 1.0,
			"params": ["mesh_ms"],
			"min_scaledown": 0,
			"w_fac": {
				"pred_dt": 0.0,
				"station_n": 10.0,
				"station_t": 10.0,
				"snap_surf_map": 0.0
			},
			"args": {
				"status_interval": 50,
				"snap_surf_map": {
					"map_opt": {
						"name": "snap_map_opt_final",
						"steps": 1,
						"lr": 0.01,
						"params": ["map_surf_ms"],
						"min_scaledown": 0,
						"args": {
							"subdiv": 1
						}
					}
				}
			}
		},
		{
			"name": "snap_light",
			"steps": 500,
			"lr": 0.1,
			"params": ["mesh_ms"],
			"min_scaledown": 0,
			"w_fac": {
				"pred_dt": 0.0,
				"snap_surf_map": 0.01,
				"station_n": 0.0,
				"station_t": 0.001
			},
			"args": {
				"status_interval": 50,
				"snap_surf_map": {
					"map_opt": {
						"name": "snap_map_opt_final",
						"steps": 1,
						"lr": 0.01,
						"params": ["map_surf_ms"],
						"min_scaledown": 0,
						"args": {
							"subdiv": 1
						}
					}
				}
			}
		},
		{
			"name": "snap",
			"steps": "auto",
			"lr": 0.1,
			"params": ["mesh_ms"],
			"min_scaledown": 0,
			"w_fac": {
				"pred_dt": 0.0,
				"snap_surf_map": 1.0,
				"station_n": 0.0,
				"station_t": 0.001
			},
			"args": {
				"status_interval": 50,
				"snap_surf_map": {
					"map_opt": {
						"name": "snap_map_opt_final",
						"steps": 1,
						"lr": 0.1,
						"params": ["map_surf_ms"],
						"min_scaledown": 0,
						"args": {
							"subdiv": 1
						}
					}
				}
			}
		}
	]
}
